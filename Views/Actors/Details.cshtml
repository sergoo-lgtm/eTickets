@model eTickets.DTO.ActorDTOS.ActorDto
@{
    ViewData["Title"] = "Actor Details";
}

<div class="row text">
    <div class="col-md-8 offset-2">
        <h1 class="text-center">Actor Details</h1>
        <div class="row">
            <div class="col-md-8 offset-2">
                
                @* عرض صورة الممثل بشكل دائري *@
                <div class="form-group text-center mb-4">
                    <img class="border-info rounded-circle" style="max-width: 150px; height: 150px; object-fit: cover;" src="@Model.ProfilePicture" alt="@Model.FullName" />
                </div>

                @* عرض الاسم (للقراءة فقط) *@
                <div class="form-group">
                    <label asp-for="FullName" class="control-label fw-bold"></label>
                    <input asp-for="FullName" class="form-control" readonly />
                </div>

                @* عرض السيرة الذاتية (للقراءة فقط) *@
                <div class="form-group">
                    <label asp-for="Bio" class="control-label fw-bold"></label>
                    <textarea asp-for="Bio" class="form-control" rows="4" readonly></textarea>
                </div>

                @* زراير التحكم *@
                <div class="form-group mt-4">
                    @* زرار التعديل (هيحتاج تكون عامل أكشن Edit) *@
                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">
                        <i class="bi bi-pencil-square"></i> Edit
                    </a>
                    
                    @* زرار الرجوع للقائمة *@
                    <a class="btn btn-outline-secondary float-right" asp-action="Index">
                        <i class="bi bi-arrow-left"></i> Show All
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>